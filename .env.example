# Database (CockroachDB Serverless)
DATABASE_URL="postgresql://user:password@host:26257/stepdish?sslmode=verify-full"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
CLERK_WEBHOOK_SECRET=""

# Cloudflare R2 Storage
# Account ID: find in Cloudflare Dashboard -> R2 -> Overview
CLOUDFLARE_ACCOUNT_ID=""
# R2 API token credentials (create under R2 -> Manage R2 API tokens)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Bucket name (must exist in your Cloudflare account)
R2_BUCKET_NAME="stepdish-images"
# Public URL for the bucket (enable public access in Cloudflare -> R2 -> bucket -> Settings)
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"

# OpenAI
OPENAI_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
